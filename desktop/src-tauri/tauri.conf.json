{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aevon",
  "version": "0.1.0",
  "identifier": "com.enzonic.aevon",
  "build": {
    "frontendDist": "https://aevon.ink",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Aevon",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Enzonic LLC",
    "copyright": "All rights reserved. Enzonic LLC",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}