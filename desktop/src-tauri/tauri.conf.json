{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Aevon",
  "version": "0.1.0",
  "identifier": "com.enzonic.aevon",
  "build": {
    "frontendDist": "https://aevon.ink",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Aevon - Novel Planning & Writing Platform",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Light"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": ["https://aevon.ink/**"]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Enzonic LLC",
    "copyright": "© 2026 Enzonic LLC. All rights reserved.",
    "licenseFile": "../LICENSE",
    "category": "Productivity",
    "shortDescription": "Professional novel planning and writing platform",
    "longDescription": "Aevon is a comprehensive novel planning and worldbuilding platform designed for authors and writers. Connect your manuscript, maps, characters, and lore in a distraction-free environment.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../LICENSE"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "tsp": false,
      "wix": {
        "language": ["en-US", "es-ES"],
        "template": "modern"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "Spanish"]
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.0-37", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libdrm2", "libxcomposite1", "libxdamage1", "libxrandr2", "libgbm1", "libxkbcommon0", "libasound2"],
        "section": "productivity"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "fs": {
      "all": true,
      "readFile": true,
      "writeFile": true,
      "readDir": true,
      "copyFile": true,
      "createDir": true,
      "removeDir": true,
      "removeFile": true,
      "renameFile": true,
      "exists": true,
      "scope": ["**"]
    },
    "sql": {
      "preload": ["./databases/app.db"]
    }
  }
}